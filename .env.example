# Octopai Project Environment Configuration
# Copy this file to .env and fill in your actual values

# ============================================
# OpenRouter API Configuration (Required)
# ============================================
# Get your API key from https://openrouter.ai
OPENROUTER_API_KEY=your_openrouter_api_key_here

# ============================================
# Cloudflare API Configuration (Optional)
# ============================================
# Used for URL to Markdown conversion
# Get these from https://dash.cloudflare.com
CLOUDFLARE_API_KEY=your_cloudflare_api_key_here
CLOUDFLARE_ACCOUNT_ID=your_cloudflare_account_id_here

# ============================================
# Model Configuration (Optional)
# ============================================
# Default model provider (currently only openrouter is supported)
OCTOPAI_MODEL_PROVIDER=openrouter

# Default model to use
# Popular choices:
# - openai/gpt-5.4 (default, good balance of cost and quality)
# - openai/gpt-5.4 (best quality)
# - anthropic/claude-4-6-sonnet
# - google/gemini-3-pro
OCTOPAI_MODEL=openai/gpt-5.4

# ============================================
# Project Configuration (Optional)
# ============================================
# Directory to store skills
SKILLS_DIR=./skills

# Directory for temporary files
TEMP_DIR=./temp

# ============================================
# Output Configuration (Optional)
# ============================================
# Default output directory
OUTPUT_DIR=./output

# Enable verbose logging
OCTOPAI_VERBOSE=0
